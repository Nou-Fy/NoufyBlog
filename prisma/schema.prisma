generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum PostSection {
  ALIMENTATION
  SANTE
  REPRODUCTION
  ASTUCE
}

enum Region {
  ANALAMANGA
  VAKINANKARATRA
  ITASY
  BONGOLAVA
  DIANA
  SAVA
  SOFIA
  BOENY
  BETSIBOKA
  MELAKY
  ALAOTRA_MANGORO
  ATSINANANA
  ANALANJIROFO
  AMORON_I_MANIA
  HAUTE_MATSIATRA
  VATOVAVY
  FITOVINANY
  ATSIMO_ATSINANANA
  IHOROMBE
  ATSIMO_ANDREFANA
  ANDROY
  ANOSY
  MENABE
}

model User {
  id       String  @id @default(cuid())
  nom      String
  prenom   String
  email    String  @unique
  password String
  role     Role    @default(USER)
  avatar   String?
  region   Region?
  archived Boolean @default(false)

  createdAt DateTime @default(now())

  posts       Post[]
  comments    Comment[]
  guides      Guide[]
  discussions Discussion[]
  responses   Response[]

  @@index([email])
}

model Post {
  id       String      @id @default(cuid())
  title    String
  content  String
  section  PostSection @default(ASTUCE)
  imageUrl String?
  archived Boolean     @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author   User   @relation(fields: [authorId], references: [id])
  authorId String

  comments Comment[]

  @@index([authorId])
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  imageUrl  String?
  createdAt DateTime @default(now())

  author   User   @relation(fields: [authorId], references: [id])
  authorId String

  // ⚠️ rendu flexible (post OU discussion)
  post   Post?   @relation(fields: [postId], references: [id])
  postId String?

  discussion   Discussion? @relation(fields: [discussionId], references: [id])
  discussionId String?

  @@index([authorId])
  @@index([postId])
  @@index([discussionId])
}

model Guide {
  id          String @id @default(cuid())
  title       String
  description String @db.VarChar(255)
  content     String @db.Text
  badge       String
  color       String @default("bg-slate-50")
  iconName    String
  slug        String @unique

  published Boolean @default(true)
  archived  Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  authorId String?
  author   User?   @relation(fields: [authorId], references: [id])

  @@index([authorId])
  @@map("guides")
}

model Discussion {
  id       String  @id @default(cuid())
  content  String  @db.VarChar(500)
  imageUrl String?
  archived Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author   User   @relation(fields: [authorId], references: [id])
  authorId String

  comments  Comment[]
  responses Response[]

  @@index([authorId])
}

model Response {
  id       String  @id @default(cuid())
  content  String  @db.VarChar(500)
  imageUrl String?
  archived Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author   User   @relation(fields: [authorId], references: [id])
  authorId String

  discussion   Discussion @relation(fields: [discussionId], references: [id])
  discussionId String

  // 🔥 réponses imbriquées (optionnel mais puissant)
  parentId String?
  parent   Response?  @relation("ResponseToResponse", fields: [parentId], references: [id])
  replies  Response[] @relation("ResponseToResponse")

  @@index([discussionId])
  @@index([authorId])
  @@index([parentId])
}
